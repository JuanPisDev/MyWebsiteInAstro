---
const {softSkill} = Astro.props;
const {skillImage} = Astro.props;
const {imageAlt} = Astro.props;

---
<div class="skill">
    <div class="skillImage"><img src={skillImage} alt={imageAlt}></div>
    <h2 class="skillName">{softSkill}</h2>
</div>


<style>
    *{
    margin:0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
    }

    .skill {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
    }

    .skill div{
        display: flex;
        justify-content: center;
    }

    .skill img{
        height: 10vh;
        width: 10vh;
        max-height: 95px;
        max-width: 95px;
    }
    
    .skill .skillImage{
        margin-bottom: 5%;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .skill h2{
        font-size: 1.4rem;
    }

    .skillName{
        width: 50%;
    }



</style>