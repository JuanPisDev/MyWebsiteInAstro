---

const {projectName} = Astro.props;
const {projectLink} = Astro.props;
const {projectImage} = Astro.props;
const {projectAlt} = Astro.props;
---
<div class="project" style={`--bg-image: url('${projectImage}');`}>
    <h2><a href={projectLink}>{projectName}</a></h2>
    <!-- <img src={projectImage} alt={projectAlt}> -->
</div>

<style>
        *{
    margin:0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
    }
    .project {
        display: block;
        background-image: var(--bg-image); 
        background-size: cover;
        background-position: center;
        width: 100%;
        height: 100%;
        border-radius: 1rem;
        border: 2px solid black;
        max-width: 250px;
    }
    .project h2{
        padding-top: 5%;
        padding-left: 5%;
        color: black;
    }
    .project h2 a:hover{
        font-weight: bolder;
        cursor: pointer;
    }
    .project h2 a{
        color: black;
        font-weight: lighter;
        text-decoration: none;
        text-shadow: 2px 2px 5px rgb(0, 0, 0)
        ;
    }
    /* .project img{
         width: 40vw;
        height: 30vw;
    } */
</style>