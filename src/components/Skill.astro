---
const {skill} = Astro.props;
const {skillImage} = Astro.props;
const {imageAlt} = Astro.props;

---
<div class="skill">
    <div class="skillImage"><img src={skillImage} alt={imageAlt}></div>
    <div class="skillName"><a>{skill}</a></div>
</div>


<style>
    *{
    margin:0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
    }

    .skill {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
    }

    .skill div{
        display: flex;
        justify-content: center;
    }

    .skill img{
        height: 10vh;
        width: 10vh;
        margin:  ;
    }
    
    .skill .skillImage{
        margin-bottom: 5%;
        border-radius: 50%;
        width: 11vh;
        height: 11vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .skillName{
        width: 100%;
    }

    .skill a{
        /* text-shadow: 1px 1px 8px white; */
        color: black;
        font-weight: bold;
        font-size: 1.1rem;
    }
    .skill a:hover{
        font-weight: bolder;
        cursor: pointer;
    }
</style>