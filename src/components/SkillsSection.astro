---
import Skill from "./Skill.astro"
---
<section id="skillsSection">
    <div class="skillsSection">
        <h1>HABILIDADES</h1>
        <ul>
            <li><Skill  skill="HTML" imageAlt="" skillImage="/skillImages/html.png"/></li>
            <li><Skill skill="CSS" imageAlt="" skillImage="/skillImages/css.png"/></li>
            <li><Skill skill="JAVASCRIPT" imageAlt="" skillImage="/skillImages/js.png"/></li>
            <li><Skill skill="REACT" imageAlt="" skillImage="/skillImages/react.webp"/></li>
            <li><Skill skill="NEXTJS" imageAlt="" skillImage="/skillImages/nextjs.webp"/></li>
            <li><Skill skill="ASTRO" imageAlt="" skillImage="/skillImages/astro.svg"/></li>

        </ul>
    </div>

</section>
<style>
    *{
    margin:0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
    }
    section{
        display: flex;
        justify-content: center;
        min-height: 50vh;
        margin: 0 0 4vh 0;

    }
    .skillsSection{
        width: 95%;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        background-color: rgb(119, 221, 119);
        border-radius: 1rem;
        box-shadow: inset 0 4px 10px rgba(0, 0, 0, 0.4);

    }

    :global(html.dark) .skillsSection{
        background-color: rgb(65, 138, 65);
    }

    .skillsSection ul{
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        justify-content: space-evenly;
        align-items: center;
        margin: 2%;
        width: 80%;
        /* border: 2px dotted black; */
        min-height: 80%;
    }
    .skillsSection ul li{
        margin: 2% 2% 5% 2%;
        display: flex;
        flex-wrap: wrap;
        flex-direction: row;
        background: linear-gradient(to right, #9a9e9a, #e9f1ec); 
        align-items: center;
        justify-content: center;
        min-height: 25vh;
        width: 40%;
        max-width: 120px;
        border-radius: 1rem;
        box-shadow: 5px 5px 8px rgba(0,0,0,0.5), 0 10px 20px rgba(0,0,0,0.2);
    }

    /* .skillsSection ul li:nth-child(1){
        transform: rotate(0deg) translate(230px) rotate(0deg);
    }
    
    .skillsSection ul li:nth-child(2){
        transform: rotate(90deg) translate(100px) rotate(-90deg);
    }
    .skillsSection ul li:nth-child(3){
        transform: rotate(180deg) translate(250px) rotate(-180deg);
    }
    .skillsSection ul li:nth-child(4){
        transform: rotate(270deg) translate(100px) rotate(-270deg);
    } */
    
    .skillsSection h1{
        text-align: center;
        width: 100%;
        /* font-weight: bolder; */
        font-weight: bold;
        font-size: 3rem;
        color: whitesmoke;
        text-shadow: 5px 5px 15px rgb(0, 0, 0)

    }
</style>