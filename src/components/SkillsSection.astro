---
import Skill from "./Skill.astro"
---
<section>
    <div class="skillsSection">
        <h1>SKILLS</h1>
        <ul>
            <li><Skill  skill="HTML"/></li>
            <li><Skill skill="CSS"/></li>
            <li><Skill skill="JAVASCRIPT"/></li>
            <li><Skill skill="REACT"/></li>
            <li><Skill skill="NEXTJS"/></li>
            <li><Skill skill="ASTRO"/></li>

        </ul>
    </div>

</section>
<style>
    *{
    margin:0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
    }
    section{
        display: flex;
        justify-content: center;
        min-height: 50vh;
        margin: 2% 0;

    }
    .skillsSection{
        width: 95%;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        background-color: rgb(119, 221, 119);
        border-radius: 1rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.2), 0 10px 20px rgba(0,0,0,0.2);

    }
    .skillsSection ul{
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        justify-content: space-evenly;
        align-items: center;
        margin: 2%;
        width: 80%;
        /* border: 2px dotted black; */
        min-height: 80%;
    }
    .skillsSection ul li{
        margin: 2%;
        display: flex;
        flex-wrap: wrap;
        flex-direction: row;
        background-color: green;
        align-items: center;
        justify-content: center;
        height: 30vh;
        width: 40%;
        max-width: 120px;
        border-radius: 1rem;
    }

    /* .skillsSection ul li:nth-child(1){
