    .skillsSection ul li:nth-child(2){
        transform: rotate(90deg) translate(100px) rotate(-90deg);
    }
    .skillsSection ul li:nth-child(3){
        transform: rotate(180deg) translate(250px) rotate(-180deg);
    }
    .skillsSection ul li:nth-child(4){
        transform: rotate(270deg) translate(100px) rotate(-270deg);
    } */
    
    .skillsSection h1{
        text-align: center;
        width: 100%;
        /* font-weight: bolder; */
        font-weight: bold;
        font-size: 3rem;
